<profile>
  <name>SonarLint IT Java Hotspot</name>
  <language>java</language>
  <rules>
    <!-- Security hotspot: unsafe logger configuration (Foo.configureLogging) -->
    <rule>
      <repositoryKey>java</repositoryKey>
      <key>S4792</key>
      <priority>BLOCKER</priority>
    </rule>

    <!-- Keep for pre 6.0 sonar-java version -->
    <rule>
      <repositoryKey>squid</repositoryKey>
      <key>S4792</key>
      <priority>BLOCKER</priority>
    </rule>

    <!-- Code smell: utility class without private constructor (Foo has only static members) -->
    <rule>
      <repositoryKey>java</repositoryKey>
      <key>S1118</key>
      <priority>MAJOR</priority>
    </rule>
  </rules>
</profile>
